# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# OpenAI Configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini

# Tavily 웹 검색 (선택 - 전략 질문 시 실시간 조사용)
# https://tavily.com 에서 무료 API 키 발급 (1,000회/월 무료)
TAVILY_API_KEY=tvly-...

# Cohere Rerank (선택 - RAG 검색 품질 향상)
# https://dashboard.cohere.com 에서 API 키 발급
# 비용: $1 / 1,000 rerank 요청 (5명 규모 월 $1 미만)
# 미설정 시 하이브리드 스코어링으로 자동 폴백
COHERE_API_KEY=

# Google Sheets (optional)
GOOGLE_SHEETS_CREDENTIALS={}
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# Meta Marketing API (애널리틱스 탭)
# Meta Business Suite → 비즈니스 설정 → 시스템 사용자 → 토큰 생성
# 필요 권한: ads_read
META_ACCESS_TOKEN=your_system_user_token

# Google Drive RAG 연동 (OAuth2 방식)
# scripts/get-drive-token.js 실행해서 아래 3개 값 발급
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxx
GOOGLE_DRIVE_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
