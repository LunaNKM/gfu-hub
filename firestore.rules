rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGfutures() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@gfutures\\.co$');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ?ВҖ?ВҖ ?СҠмҠң???ләЈлӮ« ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /users/{userId} {
      allow read: if isGfutures();
      allow write: if isOwner(userId) && isGfutures();
    }

    // ?ВҖ?ВҖ йҚ®кҫӘмҶў???СҠмҠң??(жҝЎм’“л Ү??п§ЈлҢ„кІ•?? ?кіҢлҰ° йҒәлҚҮ?) ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /disabledUsers/{email} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ?ВҖ?ВҖ ???кі—мҝӮ ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /apps/{appId} {
      allow read, write: if isGfutures();
    }

    // ?ВҖ?ВҖ ?Сүк¶Ў иҮҫлӘ„кҪҢ ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    // ?м’•мҫӯ п§Ҙ?Drive ?мҲҶлҰ°??request.auth == null)???лҚүмҠң
    match /docs/{docId} {
      allow read: if isGfutures() || request.auth == null;
      allow write: if isGfutures() || request.auth == null;
    }

    // ?ВҖ?ВҖ иҮҫлӘ„кҪҢ п§Ј?кІ• (RAG?? ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    // ?м’•мҫӯ п§Ҙ??кҫЁмҝӢ???ВҖ???лҚүмҠң
    match /docChunks/{chunkId} {
      allow read: if isGfutures() || request.auth == null;
      allow write: if isGfutures() || request.auth == null;
    }

    // ?ВҖ?ВҖ ?м’–л’Ә???г…јм ҷ (?мҲҶлҰ°???м’“м»ҷ ?? ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    // ?м’•мҫӯ п§Ҙ??лӮ…лңІ?лҢ„л“ғ ?лҚүмҠң
    match /settings/{settingId} {
      allow read: if isGfutures() || request.auth == null;
      allow write: if isGfutures() || request.auth == null;
    }

    // ?ВҖ?ВҖ AI ?ВҖ???ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /conversations/{conversationId} {
      allow read: if isGfutures() && isOwner(resource.data.userId);
      allow create: if isGfutures() && isOwner(request.resource.data.userId);
      allow update, delete: if isGfutures() && isOwner(resource.data.userId);

      match /messages/{messageId} {
        allow read, write: if isGfutures();
      }
    }

    // ?ВҖ?ВҖ AI ?СҠмҠң??жҝЎм’“л Ү ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    // ?лҢҖм”Ә?лҢҒлјө?? и№ӮлӘ„м”Ө еҜғк»Ҡмӯ” ?мҺ„лҰ°
    // ?м’•мҫӯ(request.auth == null): API ?мҮұмҠҰ?лӘ„лҝү??п§һл¬ҺнҖҺ ?кҫ©мҠң?мҮ°мӨҲп§Қ??СҠмҠң
    match /aiUsageLogs/{logId} {
      allow read: if (isGfutures() && isOwner(resource.data.userId)) || request.auth == null;
      allow create: if isGfutures() || request.auth == null;
      allow update, delete: if false;
    }

    // ?ВҖ?ВҖ ?лӮ…мӨҲ???лҡҜм”Ә ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /files/{fileId} {
      allow read: if isGfutures() && isOwner(resource.data.userId);
      allow create: if isGfutures() && isOwner(request.resource.data.userId);
      allow update, delete: if isGfutures() && isOwner(resource.data.userId);
    }

    // ?ВҖ?ВҖ ?СҠмҠң???г…јм ҷ ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /userSettings/{userId} {
      allow read, write: if isGfutures() && isOwner(userId);
    }

    // ?ВҖ?ВҖ п§ҰмўҸлҹ№???лҚҲнҲ• ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    // ?м’•мҫӯ(API ?мҮұмҠҰ???лЁҜкҪҢ???л¬Һл җ еӘӣВҖ?ОҪлёҜ?кҫЁмӨү request.auth == null ?лҚүмҠң
    match /campaigns/{campaignId} {
      allow read, write: if isGfutures() || isAuthenticated() || request.auth == null;
    }

    // ?ВҖ?ВҖ п§ҰмўҸлҹ№???лҡ°кІ•?лҡ®мӨҲ???м’–л’Ә???ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /campaignTasks/{taskId} {
      allow read, write: if isGfutures();
    }

    // ?ВҖ?ВҖ п§ҰмўҸлҹ№???лҡ°кІ•?г…Ҫлҹ№?лҢҒл’Ә ?лұҖлҖЎ ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /campaignSections/{sectionId} {
      allow read, write: if isGfutures() || isAuthenticated();
    }

    match /campaignBlocks/{blockId} {
      allow read, write: if isGfutures() || isAuthenticated();
    }

    match /campaignDatabases/{databaseId} {
      allow read, write: if isGfutures() || isAuthenticated();
    }

    match /campaignDatabaseRows/{rowId} {
      allow read, write: if isGfutures() || isAuthenticated();
    }

    match /campaignMetaMappings/{mappingId} {
      allow read, write: if isGfutures() || isAuthenticated();
    }

    match /campaignMetaInsightSnapshots/{snapshotId} {
      allow read, write: if isGfutures() || isAuthenticated();
    }

    // ?ВҖ?ВҖ п§ҰмўҸлҹ№?лӘғнҖҺ ?лӘ…лөҶзҢ·в‘Ҙлјө???лЁҜлӢ” ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /influencerScores/{scoreId} {
      allow read, write: if isGfutures();
    }

    // ?ВҖ?ВҖ AI ?лӮ…Рў ?г…Ҫл»ҫ ж№Ікі•мӨү ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /aiActionRuns/{runId} {
      allow read, write: if isGfutures();
    }

    // ?ВҖ?ВҖ ?лӘ…лөҶзҢ·в‘Ҙлјө??CRM ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    // Sheets ?мҲҶлҰ°?????м’•мҫӯ(API ?мҮұмҠҰ???лЁҜкҪҢ upsert ??request.auth == null ?лҚүмҠң
    match /influencers/{influencerId} {
      allow read, write: if isGfutures() || request.auth == null;
    }

    // ?ВҖ?ВҖ ?мҮ°лӮҜ ?м’–мҳЈ ?лӘ…лҖӣз”ұСҠмҹҫ??йҮүлҡ®в”Ғ???ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    // Cron / ?м„ҺлЈһ ?м•№кҪҰ п§Ҹв‘ӨлӘў ?м’•мҫӯ?лЁҜкҪҢ addDoc ??request.auth == null ?лҚүмҠң
    match /marketBriefs/{briefId} {
      allow read, write: if isGfutures() || request.auth == null;
    }

    // ?ВҖ?ВҖ ?ВҖ?ОҪмӮҺ ?м’–мҳЈ ?лӘ…лҖӣз”ұСҠмҹҫ???ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    match /trendSignals/{signalId} {
      allow read, write: if isGfutures();
    }

    match /brandImpacts/{impactId} {
      allow read, write: if isGfutures();
    }

    match /competitorWatches/{watchId} {
      allow read, write: if isGfutures();
    }

    match /weeklyMarketReports/{reportId} {
      allow read, write: if isGfutures();
    }

    // ?ВҖ?ВҖ ?ОәлҰ° ж№Ікі—лјІ ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
    // ?ВҖ?О’лЈ№вҖң??п§Ҹв‘ӨлӘў ?м’•мҫӯ(API ?мҮұмҠҰ???лЁҜкҪҢ ?г…Ҫл»ҫ ??request.auth == null ?лҚүмҠң
    // ?лҢҖм”Ә?лҢҒлјө?лӘ„лҝү?м’•л’— и№ӮлӘ„м”Ө еҜғк»Ҡмӯ” ?мҺ„лҰ° еӘӣВҖ??(иӘҳлӘғмҳ’ UI??
    match /memories/{memoryId} {
      allow read: if (isGfutures() && isOwner(resource.data.userId)) || request.auth == null;
      allow create: if isGfutures() || request.auth == null;
      allow update, delete: if false;
    }
  }
}
