rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isGfuturesEmail() {
      return isAuthenticated() && request.auth.token.email.matches('.*@gfutures\\.co$');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isGfuturesEmail();
      allow write: if isOwner(userId) && isGfuturesEmail();
    }

    // Disabled users (read-only for auth check)
    match /disabledUsers/{email} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin only
    }

    // Apps collection
    match /apps/{appId} {
      allow read: if isGfuturesEmail();
      allow write: if isGfuturesEmail();
    }

    // Docs collection
    match /docs/{docId} {
      allow read: if isGfuturesEmail();
      allow write: if isGfuturesEmail();
    }

    // Doc chunks collection
    match /docChunks/{chunkId} {
      allow read: if isGfuturesEmail();
      allow write: if isGfuturesEmail();
    }

    // Conversations collection
    match /conversations/{conversationId} {
      allow read: if isGfuturesEmail() && isOwner(resource.data.userId);
      allow create: if isGfuturesEmail() && isOwner(request.resource.data.userId);
      allow update, delete: if isGfuturesEmail() && isOwner(resource.data.userId);

      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isGfuturesEmail();
      }
    }

    // AI Usage logs
    match /aiUsageLogs/{logId} {
      allow read: if isGfuturesEmail() && isOwner(resource.data.userId);
      allow create: if isGfuturesEmail() && isOwner(request.resource.data.userId);
      allow update, delete: if false;
    }

    // Files collection
    match /files/{fileId} {
      allow read: if isGfuturesEmail() && isOwner(resource.data.userId);
      allow create: if isGfuturesEmail() && isOwner(request.resource.data.userId);
      allow update, delete: if isGfuturesEmail() && isOwner(resource.data.userId);
    }

    // User settings
    match /userSettings/{userId} {
      allow read, write: if isGfuturesEmail() && isOwner(userId);
    }
  }
}
